@{
    ViewData["Title"] = "Cloud Application Development Resources";
}

<div class="container mt-4">
    <h1 class="text-center mb-4">Cloud Application Development Resources</h1>
    <p class="lead text-center">
        Empower your skills in cloud application development with these comprehensive resources. Whether you're an aspiring developer or an experienced professional, these materials are designed to teach you how to build, deploy, and manage cutting-edge applications in the cloud. Gain hands-on experience with industry-leading tools, frameworks, and best practices for developing scalable and efficient cloud-based solutions.
    </p>

    <div class="row mt-5">
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Cloud Development Bootcamp</h5>
                    <p class="card-text">
                        This immersive bootcamp offers a step-by-step guide to building cloud-native applications. Learn key concepts like microservices architecture, containerization, and continuous deployment, using modern tools such as Docker and Kubernetes.
                    </p>
                    <a href="https://www.codecademy.com/learn" class="link-resource">Open Resource</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Developing on AWS</h5>
                    <p class="card-text">
                        This resource provides an in-depth introduction to designing, building, and deploying applications on Amazon Web Services (AWS). Learn essential AWS services like Lambda, DynamoDB, and API Gateway, along with practical projects to solidify your understanding.
                    </p>
                    <a href="https://aws.amazon.com/getting-started/?nc2=h_ql_le_gs" class="link-resource">Open Resource</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Microsoft Learn: App Development</h5>
                    <p class="card-text">
                        Explore the world of cloud application development with Microsoft's free interactive learning platform. This course covers Azure App Services, Azure Functions, and other essential tools for creating, deploying, and scaling applications in the cloud.
                    </p>
                    <a href="https://learn.microsoft.com/en-us/training/" class="link-resource">Open Resource</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Full-Stack Cloud Development</h5>
                    <p class="card-text">
                        This specialization, offered by IBM on Coursera, teaches you how to develop full-stack cloud-based applications. Dive into topics like front-end frameworks, server-side scripting, and database integration, along with DevOps practices for continuous delivery.
                    </p>
                    <a href="https://www.coursera.org/specializations/ibm-cloud-application-development-foundations?" class="link-resource">Open Resource</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Google Cloud Application Development</h5>
                    <p class="card-text">
                        Google Cloud's comprehensive learning platform offers tutorials, labs, and certifications to help you master cloud app development. From setting up scalable backend systems to deploying serverless functions, this resource is ideal for beginners and experts alike.
                    </p>
                    <a href="https://cloud.google.com/training" class="link-resource">Open Resource</a>
                </div>
            </div>
        </div>
        <div class="col-md-4 mb-4">
            <div class="card h-100 shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">IBM Application Development</h5>
                    <p class="card-text">
                        Dive into IBM's developer portal to learn about creating cloud-native applications using IBM Cloud services. This resource includes tutorials, sample projects, and access to tools like Watson AI and Kubernetes for advanced app development.
                    </p>
                    <a href="https://developer.ibm.com" class="link-resource">Open Resource</a>
                </div>
            </div>
        </div>
    </div>
</div>
